# Copy this file to .env and fill in your values.
# pylib_finder loads it automatically — no shell exports needed.

# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — raises GitHub API rate limit from 10 to 30 req/min.
# Create a classic token at https://github.com/settings/tokens (no scopes needed).
GITHUB_TOKEN=
